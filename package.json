{
	"name": "code-jump",
	"displayName": "code-jump",
	"description": "",
	"version": "1.2.8",
	"icon": "image/logo.png",
	"engines": {
		"vscode": "^1.38.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:extension.jumpReference",
		"onCommand:extension.jumpNextReference",
		"onCommand:extension.jumpPrevReference",
		"onView:targetReference",
		"onCommand:itemClick"
	],
	"main": "./extension.js",
	"contributes": {
		"commands": [{
            "command": "extension.jumpReference",
			"title": "%cmd.jumpReference%"
		},{
            "command": "extension.jumpNextReference",
			"title": "%cmd.jumpNextReference%"
		},{
            "command": "extension.jumpPrevReference",
			"title": "%cmd.jumpPrevReference%"
		},{
            "command": "extension.expandAllReference",
			"title": "%cmd.expandAll%",
			"icon": "$(expand-all)"
		},{
            "command": "extension.collapseAllReference",
			"title": "%cmd.collapseAll%",
			"icon": "$(collapse-all)"
		}],

		"menus": {
			"view/title": [
				{
					"command": "extension.collapseAllReference",
					"when": "view == targetReference && !codeJump.allCollapsed",
					"group": "navigation@1"
				},
				{
					"command": "extension.expandAllReference",
					"when": "view == targetReference && codeJump.allCollapsed",
					"group": "navigation@1"
				}
			]
		},

		"configuration": {
			"type": "object",
			"properties": {
				"code jump.rgPath":{
					"type": "string",
					"default": "rg",
					"description": "%config.rgPath.desc%"
				}
			}
		},

		"viewsContainers": {
			"activitybar": [
				{
					"id": "show-reference",
					"title": "%viewContainer.title%",
					"icon": "image/ref.svg"
				}
			]
		},
		"views": {
			"show-reference": [
				{
					"id": "targetReference",
					"name": ""
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "targetReference",
				"contents": "%view.welcome%"
			}
		]
	},
	"scripts": {
		"test": "node ./test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/mocha": "^5.2.6",
		"@types/node": "^10.12.21",
		"@types/vscode": "^1.38.0",
		"eslint": "^5.13.0",
		"glob": "^7.1.4",
		"mocha": "^6.1.4",
		"typescript": "^3.3.1",
		"vscode-test": "^1.2.0"
	},
	"publisher": "senlin"
}
