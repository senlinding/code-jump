{
	"name": "code-jump",
	"displayName": "code-jump",
	"description": "",
	"version": "1.2.8",
	"icon": "image/logo.png",
	"engines": {
		"vscode": "^1.38.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onCommand:extension.jumpReference",
		"onCommand:extension.jumpNextReference",
		"onCommand:extension.jumpPrevReference",
		"onView:targetReference",
		"onCommand:itemClick"
	],
	"main": "./extension.js",
	"contributes": {
		"commands": [{
            "command": "extension.jumpReference",
			"title": "jump reference"
		},{
            "command": "extension.jumpNextReference",
			"title": "jump next reference"
		},{
            "command": "extension.jumpPrevReference",
			"title": "jump prev reference"
		},{
            "command": "extension.expandAllReference",
			"title": "全部展开",
			"icon": "$(expand-all)"
		},{
            "command": "extension.collapseAllReference",
			"title": "全部折叠",
			"icon": "$(collapse-all)"
		}],

		"menus": {
			"view/title": [
				{
					"command": "extension.collapseAllReference",
					"when": "view == targetReference && !codeJump.allCollapsed",
					"group": "navigation@1"
				},
				{
					"command": "extension.expandAllReference",
					"when": "view == targetReference && codeJump.allCollapsed",
					"group": "navigation@1"
				}
			]
		},

		"configuration": {
			"type": "object",
			"properties": {
				"code jump.rgPath":{
					"type": "string",
					"default": "rg",
					"description": "ripgrep path"
				}
			}
		},

		"viewsContainers": {
			"activitybar": [
				{
					"id": "show-reference",
					"title": "Code Reference",
					"icon": "image/ref.svg"
				}
			]
		},
		"views": {
			"show-reference": [
				{
					"id": "targetReference",
					"name": "info"
				}
			]
		},
		"viewsWelcome": [
			{
				"view": "targetReference",
				"contents": "暂无引用结果。\n将光标放在某个符号上，执行 jump reference 命令以查找引用。"
			}
		]
	},
	"scripts": {
		"test": "node ./test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/mocha": "^5.2.6",
		"@types/node": "^10.12.21",
		"@types/vscode": "^1.38.0",
		"eslint": "^5.13.0",
		"glob": "^7.1.4",
		"mocha": "^6.1.4",
		"typescript": "^3.3.1",
		"vscode-test": "^1.2.0"
	},
	"publisher": "senlin"
}
